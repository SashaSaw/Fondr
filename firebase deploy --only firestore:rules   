rules_version = '2';
  service cloud.firestore {
    match /databases/{database}/documents {

      // User documents: only the owner can read/write
      match /users/{userId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Pair documents: only members can read/write
      match /pairs/{pairId} {
        allow read, write: if request.auth != null &&
          (request.auth.uid == resource.data.userA || request.auth.uid ==
  resource.data.userB);

        // Allow creating a pair if the user is userA
        allow create: if request.auth != null &&
          request.auth.uid == request.resource.data.userA;

        // Subcollections inherit pair member access
        match /{subcollection}/{docId} {
          allow read, write: if request.auth != null &&
            (request.auth.uid ==
  get(/databases/$(database)/documents/pairs/$(pairId)).data.userA ||
             request.auth.uid ==
  get(/databases/$(database)/documents/pairs/$(pairId)).data.userB);
        }
      }

      // Allow querying pairs by invite code for joining
      match /pairs/{pairId} {
        allow read: if request.auth != null &&
          resource.data.status == "pending";
      }
    }
  }